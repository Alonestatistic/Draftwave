{
  "name": "draftwave",
  "version": "0.1.0",
  "description": "Draftwave desktop shell and renderer prototype",
  "author": "Draftwave Alpha",
  "main": "electron/main.cjs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "smoke": "node scripts/smoke-alpha.mjs",
    "test": "node --test tests/*.test.mjs",
    "integration": "node scripts/integration-alpha.cjs",
    "release:manifest": "node scripts/write-release-manifest.mjs",
    "alpha4:stopship": "node scripts/alpha4-stopship.mjs",
    "check": "npm run test && npm run smoke && npm run alpha4:stopship && npm run build && npm run integration",
    "desktop": "electron .",
    "start": "concurrently -k \"npm:dev\" \"wait-on http://127.0.0.1:5173/Draftwave.html && electron .\"",
    "preview": "vite preview --host 127.0.0.1",
    "package:win": "npm run build && npm run release:manifest && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.draftwave.alpha",
    "productName": "Draftwave",
    "artifactName": "draftwave-${version}-${os}-${arch}.${ext}",
    "extraMetadata": {
      "alphaPhase": "Alpha 4",
      "releaseChannel": "private-alpha"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "publisherName": "Draftwave Alpha"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron-builder": "^24.13.3",
    "electron": "^31.7.7",
    "vite": "^5.4.19",
    "wait-on": "^7.2.0"
  }
}
