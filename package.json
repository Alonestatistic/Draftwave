{
  "name": "draftwave",
  "version": "0.1.0",
  "description": "Draftwave desktop DAW",
  "author": "Draftwave",
  "main": "electron/main.cjs",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "smoke": "node scripts/smoke.mjs",
    "test": "node --test tests/*.test.mjs",
    "check": "npm run test && npm run smoke && npm run build",
    "desktop": "electron .",
    "start": "concurrently -k \"npm:dev\" \"wait-on http://127.0.0.1:5173/Draftwave.html && electron .\"",
    "preview": "vite preview --host 127.0.0.1",
    "release:manifest": "node scripts/write-release-manifest.mjs",
    "copy:installer": "node scripts/copy-win-installer.mjs",
    "package:win": "npm run build && npm run release:manifest && electron-builder --win --x64 --publish never && npm run copy:installer",
    "dist:win": "npm run package:win"
  },
  "build": {
    "appId": "com.draftwave.app",
    "productName": "Draftwave",
    "artifactName": "Draftwave-Setup-${version}-${arch}.${ext}",
    "asar": true,
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.ico",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ],
      "publisherName": "Draftwave"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Draftwave"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron-builder": "^24.13.3",
    "electron": "^31.7.7",
    "vite": "^5.4.19",
    "wait-on": "^7.2.0"
  }
}
